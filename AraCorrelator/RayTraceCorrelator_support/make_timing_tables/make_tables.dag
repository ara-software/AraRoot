CONFIG config.dagman

## Station 1
# Up
JOB st1_r300_sysup   make_tables.sub
VARS st1_r300_sysup  nodename="$(JOB)" station="100" outputdir="/scratch/amachtay/ray_trace_tables/up" radius="300" systematic="1"

JOB st1_r40_sysup1   make_tables.sub
VARS st1_r40_sysup1  nodename="$(JOB)" station="100" outputdir="/scratch/amachtay/ray_trace_tables/up" radius="48.02" systematic="1"

JOB st1_r40_sysup2   make_tables.sub
